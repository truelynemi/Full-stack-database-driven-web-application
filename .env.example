# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to Git.

# Flask secret key — change this to a long random string in production
SECRET_KEY=change-me-to-a-long-random-string

# -------------------------------------------------------
# Gmail SMTP (for sending verification + reset emails)
# -------------------------------------------------------
# Use your Gmail address
GMAIL_ADDRESS=you@gmail.com
# Use an App Password (NOT your real Gmail password)
# How to get one:
#   1. Enable 2-Step Verification on your Google account
#   2. Go to: myaccount.google.com/apppasswords
#   3. Create a new app password (select "Mail" and "Windows Computer")
#   4. Paste the 16-character code below
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# -------------------------------------------------------
# Google OAuth
# -------------------------------------------------------
# How to get credentials:
#   1. Go to: console.cloud.google.com
#   2. Create a new project
#   3. Go to APIs & Services > Credentials
#   4. Click "Create Credentials" > OAuth client ID
#   5. Set application type to "Web application"
#   6. Add http://127.0.0.1:5000/auth/google/callback as an Authorized redirect URI
#   7. Copy the Client ID and Client Secret below
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# -------------------------------------------------------
# Twitter / X OAuth 1.0a
# -------------------------------------------------------
# How to get credentials:
#   1. Go to: developer.twitter.com
#   2. Sign in and create a new project + app
#   3. Under your app, go to "Keys and Tokens"
#   4. Copy the API Key and API Secret below
#   5. In your app settings, set the Callback URL to:
#      http://127.0.0.1:5000/auth/twitter/callback
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
